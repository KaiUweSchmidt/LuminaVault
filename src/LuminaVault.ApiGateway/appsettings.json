{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "media-import-route": {
        "ClusterId": "media-import",
        "Match": {
          "Path": "/api/media/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/media" }
        ]
      },
      "metadata-storage-route": {
        "ClusterId": "metadata-storage",
        "Match": {
          "Path": "/api/metadata/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/metadata" }
        ]
      },
      "ai-tagging-route": {
        "ClusterId": "ai-tagging",
        "Match": {
          "Path": "/api/tags/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/tags" }
        ]
      },
      "vector-search-route": {
        "ClusterId": "vector-search",
        "Match": {
          "Path": "/api/search/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/search" }
        ]
      },
      "thumbnail-generation-route": {
        "ClusterId": "thumbnail-generation",
        "Match": {
          "Path": "/api/thumbnails/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/thumbnails" }
        ]
      },
      "object-recognition-route": {
        "ClusterId": "object-recognition",
        "Match": {
          "Path": "/api/recognition/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/recognition" }
        ]
      }
    },
    "Clusters": {
      "media-import": {
        "Destinations": {
          "primary": {
            "Address": "http://media-import:8080"
          }
        }
      },
      "metadata-storage": {
        "Destinations": {
          "primary": {
            "Address": "http://metadata-storage:8080"
          }
        }
      },
      "ai-tagging": {
        "Destinations": {
          "primary": {
            "Address": "http://ai-tagging:8080"
          }
        }
      },
      "vector-search": {
        "Destinations": {
          "primary": {
            "Address": "http://vector-search:8080"
          }
        }
      },
      "thumbnail-generation": {
        "Destinations": {
          "primary": {
            "Address": "http://thumbnail-generation:8080"
          }
        }
      },
      "object-recognition": {
        "Destinations": {
          "primary": {
            "Address": "http://object-recognition:8080"
          }
        }
      }
    }
  }
}
