@page "/"
@using LuminaVault.WebUI.Services
@inject MediaApiClient MediaApi
@rendermode InteractiveServer

<PageTitle>LuminaVault - Media Library</PageTitle>

<h1>LuminaVault</h1>
<p>AI-powered media management &amp; search</p>

<div>
    <input @bind="searchQuery" @bind:event="oninput" placeholder="Search media..." />
    <button @onclick="SearchMedia">Search</button>
</div>

@if (isLoading)
{
    <p>Loading...</p>
}
else if (mediaItems.Count == 0)
{
    <p>No media found. Start by importing files.</p>
}
else
{
    <ul>
        @foreach (var item in mediaItems)
        {
            <li>
                <strong>@item.Title</strong>
                <span>@string.Join(", ", item.Tags)</span>
                <small>@item.CreatedAt.ToString("yyyy-MM-dd")</small>
            </li>
        }
    </ul>
}

@code {
    private List<MediaItem> mediaItems = [];
    private string searchQuery = string.Empty;
    private bool isLoading = false;

    protected override async Task OnInitializedAsync() => await LoadMediaAsync();

    private async Task LoadMediaAsync()
    {
        isLoading = true;
        try { mediaItems = await MediaApi.GetMediaAsync(); }
        finally { isLoading = false; }
    }

    private async Task SearchMedia()
    {
        isLoading = true;
        try { mediaItems = await MediaApi.GetMediaAsync(search: searchQuery); }
        finally { isLoading = false; }
    }
}

