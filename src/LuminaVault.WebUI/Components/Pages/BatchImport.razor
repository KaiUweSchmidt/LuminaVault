@page "/batch-import"
@using LuminaVault.WebUI.Services
@inject BatchImportService ImportService
@inject BatchImportCircuitHandler CircuitHandler
@inject HostMediaPathService HostMediaPath
@rendermode InteractiveServer
@implements IDisposable

<div class="batch-import-page">
    <h1>📂 Verzeichnis importieren</h1>
    <p class="import-description">
        Wähle ein Basisverzeichnis auf dem Server. Alle gültigen Mediendateien werden rekursiv gefunden und importiert.
    </p>

    @if (ImportService.Status == BatchImportStatus.Idle || ImportService.Status == BatchImportStatus.Cancelled)
    {
        <div class="batch-dir-form">
            <label class="batch-dir-label" for="dirInput">Verzeichnispfad</label>
            <div class="batch-dir-row">
                <input id="dirInput"
                       class="batch-dir-input"
                       type="text"
                       placeholder="/media/import"
                       @bind="_directoryPath"
                       @bind:event="oninput"
                       disabled="@_isStarting" />
                <button class="btn-browse"
                        @onclick="ToggleBrowser"
                        disabled="@_isStarting"
                        title="Verzeichnis durchsuchen">
                    📁
                </button>
                <button class="btn-upload"
                        @onclick="StartImportAsync"
                        disabled="@(string.IsNullOrWhiteSpace(_directoryPath) || _isStarting)">
                    @(_isStarting ? "Wird gescannt..." : "Import starten")
                </button>
            </div>

            @if (_showBrowser)
            {
                <div class="dir-browser" @onkeydown="HandleBrowserKeyDown">
                    <div class="dir-browser-header">
                        <span class="dir-browser-path">@_browsePath</span>
                    </div>
                    <div class="dir-browser-list" tabindex="0" @ref="_browserListRef">
                        @if (_browsePath != _browseRoot)
                        {
                            <div class="dir-browser-item dir-browser-up @(_browseSelectedIndex == -1 ? "dir-browser-selected" : "")"
                                 @onclick="BrowseUp"
                                 @ondblclick="BrowseUp">
                                <span>⬆️ ..</span>
                            </div>
                        }
                        @if (_browseError is not null)
                        {
                            <div class="error-message" style="margin:0.5rem 0">@_browseError</div>
                        }
                        else if (_browseDirectories.Count == 0)
                        {
                            <div class="dir-browser-empty">Keine Unterverzeichnisse</div>
                        }
                        else
                        {
                            @for (var i = 0; i < _browseDirectories.Count; i++)
                            {
                                var idx = i;
                                var dir = _browseDirectories[idx];
                                <div class="dir-browser-item @(idx == _browseSelectedIndex ? "dir-browser-selected" : "")"
                                     @onclick="() => SelectBrowserItem(idx)"
                                     @ondblclick="() => BrowseInto(dir)">
                                    <span>📂 @Path.GetFileName(dir)</span>
                                </div>
                            }
                        }
                    </div>
                    <div class="dir-browser-actions">
                        <button class="btn-upload" @onclick="SelectBrowsePath">Auswählen</button>
                        <button class="btn-clear" @onclick="CloseBrowser">Schließen</button>
                    </div>
                </div>
            }

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="error-message" style="margin-top:0.75rem">@_errorMessage</div>
            }
        </div>
    }
    else
    {
        <div class="batch-status-card">
            <div class="batch-status-header">
                <span class="batch-status-badge @StatusCssClass">@StatusLabel</span>
                <span class="batch-dir-display">@ImportService.DirectoryPath</span>
            </div>

            @if (ImportService.Status == BatchImportStatus.Scanning)
            {
                <div class="batch-scanning">Verzeichnis wird durchsucht...</div>
            }
            else
            {
                <div class="batch-progress-section">
                    <div class="batch-progress-bar-wrap">
                        <div class="batch-progress-bar" style="width: @ImportService.ProgressPercent.ToString("F1")%"></div>
                    </div>
                    <div class="batch-progress-labels">
                        <span>@ImportService.ImportedCount erfolgreich &nbsp; @ImportService.ErrorCount Fehler &nbsp; von @ImportService.TotalFiles</span>
                        <span>@ImportService.ProgressPercent.ToString("F1")%</span>
                    </div>
                </div>

                <div class="batch-stats">
                    <div class="batch-stat">
                        <span class="batch-stat-label">Durchschn. Upload</span>
                        <span class="batch-stat-value">
                            @if (ImportService.AverageUploadTime is { } avgUpload)
                            {
                                @FormatDuration(avgUpload)
                            }
                            else
                            {
                                <span>-</span>
                            }
                        </span>
                    </div>
                    <div class="batch-stat">
                        <span class="batch-stat-label">Durchschn. Pipeline (E2E)</span>
                        <span class="batch-stat-value">
                            @if (ImportService.AverageImportTime is { } avg)
                            {
                                @FormatDuration(avg)
                            }
                            else
                            {
                                <span>-</span>
                            }
                        </span>
                    </div>
                    <div class="batch-stat">
                        <span class="batch-stat-label">ETA</span>
                        <span class="batch-stat-value">
                            @if (ImportService.EstimatedTimeRemaining is { } eta)
                            {
                                @FormatDuration(eta)
                            }
                            else
                            {
                                <span>-</span>
                            }
                        </span>
                    </div>
                    <div class="batch-stat">
                        <span class="batch-stat-label">Pipeline fertig</span>
                        <span class="batch-stat-value">@ImportService.PipelineCompletedCount / @ImportService.ImportedCount</span>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(ImportService.CurrentFile))
                {
                    <div class="batch-current-file">
                        <span class="spinner">&#x23F3;</span>&nbsp;@ImportService.CurrentFile
                    </div>
                }

                <div class="batch-actions">
                    @if (ImportService.Status == BatchImportStatus.Running)
                    {
                        <button class="btn-clear" @onclick="ImportService.Pause">Pausieren</button>
                    }
                    else if (ImportService.Status == BatchImportStatus.Paused)
                    {
                        <button class="btn-upload" @onclick="ResumeAsync">Weiterführen</button>
                    }

                    @if (ImportService.Status != BatchImportStatus.Completed)
                    {
                        <button class="btn-danger" @onclick="ImportService.Cancel"
                                disabled="@(ImportService.Status == BatchImportStatus.Scanning)">
                            Abbrechen
                        </button>
                    }

                    @if (ImportService.Status is BatchImportStatus.Completed or BatchImportStatus.Cancelled)
                    {
                        <button class="btn-clear" @onclick="ImportService.Reset">Neuer Import</button>
                    }
                </div>

                @if (ImportService.Status == BatchImportStatus.Completed)
                {
                    <div class="upload-success">
                        Import abgeschlossen - @ImportService.ImportedCount Datei(en) importiert, @ImportService.ErrorCount Fehler.
                    </div>
                }
            }
        </div>
    }
</div>

@code {
    private string? _directoryPath;
    private string? _errorMessage;
    private bool _isStarting;

    private bool _showBrowser;
    private string _browseRoot = "/media/import";
    private string _browsePath = "/media/import";
    private List<string> _browseDirectories = [];
    private string? _browseError;
    private int _browseSelectedIndex = -1;
    private ElementReference _browserListRef;

    protected override void OnInitialized()
    {
        ImportService.OnProgressChanged += HandleProgress;

        _browseRoot = HostMediaPath.HostMediaPath;
        _browsePath = _browseRoot;

        // Pre-fill the directory input with the configured host-mount path.
        if (string.IsNullOrEmpty(_directoryPath))
            _directoryPath = HostMediaPath.HostMediaPath;

        // Register this circuit as the import owner so the circuit handler
        // can pause the import if this tab/window is closed.
        if (CircuitHandler.CircuitId is { } id)
            ImportService.SetOwner(id);
    }

    public void Dispose()
    {
        ImportService.OnProgressChanged -= HandleProgress;
    }

    private void HandleProgress()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private async Task StartImportAsync()
    {
        if (string.IsNullOrWhiteSpace(_directoryPath)) return;
        _errorMessage = null;
        _isStarting = true;
        StateHasChanged();

        try
        {
            await ImportService.StartAsync(_directoryPath.Trim());
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
            ImportService.Reset();
        }
        finally
        {
            _isStarting = false;
        }
    }

    private async Task ResumeAsync()
    {
        // Re-register ownership so the new circuit can pause on browser close.
        if (CircuitHandler.CircuitId is { } id)
            ImportService.SetOwner(id);

        await ImportService.ResumeAsync();
    }

    private string StatusLabel => ImportService.Status switch
    {
        BatchImportStatus.Scanning   => "Scannen...",
        BatchImportStatus.Running    => "Importiert...",
        BatchImportStatus.Paused     => "Pausiert",
        BatchImportStatus.Completed  => "Abgeschlossen",
        BatchImportStatus.Cancelled  => "Abgebrochen",
        _                            => ""
    };

    private string StatusCssClass => ImportService.Status switch
    {
        BatchImportStatus.Running    => "status-running",
        BatchImportStatus.Paused     => "status-paused",
        BatchImportStatus.Completed  => "status-completed",
        BatchImportStatus.Cancelled  => "status-cancelled",
        _                            => "status-scanning"
    };

    private async Task ToggleBrowser()
    {
        _showBrowser = !_showBrowser;
        if (_showBrowser)
        {
            _browsePath = !string.IsNullOrWhiteSpace(_directoryPath) && Directory.Exists(_directoryPath)
                ? _directoryPath
                : _browseRoot;
            LoadBrowseDirectories();
            await FocusBrowserListAsync();
        }
    }

    private void CloseBrowser()
    {
        _showBrowser = false;
    }

    private async Task FocusBrowserListAsync()
    {
        await Task.Yield();
        try { await _browserListRef.FocusAsync(); } catch { /* element may not be rendered yet */ }
    }

    private void LoadBrowseDirectories()
    {
        _browseError = null;
        _browseDirectories = [];
        _browseSelectedIndex = -1;
        try
        {
            if (!Directory.Exists(_browsePath))
            {
                _browseError = $"Verzeichnis nicht gefunden: {_browsePath}";
                return;
            }
            _browseDirectories = Directory.GetDirectories(_browsePath)
                .OrderBy(d => Path.GetFileName(d), StringComparer.OrdinalIgnoreCase)
                .ToList();
        }
        catch (UnauthorizedAccessException)
        {
            _browseError = "Zugriff verweigert.";
        }
        catch (Exception ex)
        {
            _browseError = ex.Message;
        }
    }

    private void SelectBrowserItem(int index)
    {
        _browseSelectedIndex = index;
    }

    private void BrowseInto(string dir)
    {
        _browsePath = dir;
        LoadBrowseDirectories();
    }

    private void BrowseUp()
    {
        var parent = Path.GetDirectoryName(_browsePath);
        if (parent is not null && parent.StartsWith(_browseRoot, StringComparison.Ordinal))
        {
            _browsePath = parent;
            LoadBrowseDirectories();
        }
        else
        {
            _browsePath = _browseRoot;
            LoadBrowseDirectories();
        }
    }

    private void HandleBrowserKeyDown(KeyboardEventArgs e)
    {
        var maxIndex = _browseDirectories.Count - 1;
        var hasParent = _browsePath != _browseRoot;

        switch (e.Key)
        {
            case "ArrowDown":
                if (_browseSelectedIndex < maxIndex)
                    _browseSelectedIndex++;
                break;

            case "ArrowUp":
                if (_browseSelectedIndex > (hasParent ? -1 : 0))
                    _browseSelectedIndex--;
                break;

            case "Enter":
                if (_browseSelectedIndex == -1 && hasParent)
                    BrowseUp();
                else if (_browseSelectedIndex >= 0 && _browseSelectedIndex <= maxIndex)
                    BrowseInto(_browseDirectories[_browseSelectedIndex]);
                break;

            case "Backspace":
                if (hasParent)
                    BrowseUp();
                break;

            case "Escape":
                _showBrowser = false;
                break;
        }
    }

    private void SelectBrowsePath()
    {
        if (_browseSelectedIndex >= 0 && _browseSelectedIndex < _browseDirectories.Count)
            _directoryPath = _browseDirectories[_browseSelectedIndex];
        else
            _directoryPath = _browsePath;
        _showBrowser = false;
    }

    private static string FormatDuration(TimeSpan ts)
    {
        if (ts.TotalSeconds < 60) return $"{ts.TotalSeconds:F1} s";
        if (ts.TotalMinutes < 60) return $"{(int)ts.TotalMinutes} min {ts.Seconds} s";
        return $"{(int)ts.TotalHours} h {ts.Minutes} min";
    }
}
