@page "/gallery"
@using LuminaVault.WebUI.Services
@inject MediaApiClient MediaApi
@inject GalleryUserSettingsService GallerySettings
@rendermode InteractiveServer

<div class="gallery-page">
    <h1>🖼️ Medienbibliothek</h1>
    <p class="gallery-description">Übersicht aller importierten Medien mit Thumbnails.</p>

    @if (_isLoading)
    {
        <div class="loading-message">Lade Medien…</div>
    }
    else if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="error-message">@_errorMessage</div>
    }
    else if (_mediaItems.Count == 0)
    {
        <div class="gallery-empty">
            <span class="gallery-empty-icon">📭</span>
            <p>Noch keine Medien importiert.</p>
            <a href="import" class="btn-upload">Jetzt importieren</a>
        </div>
    }
    else
    {
        <div class="gallery-split">
            <div class="gallery-list">
                <table class="media-grid">
                    <thead>
                        <tr>
                            <th class="col-thumb">Thumbnail</th>
                            <th class="col-date sortable" @onclick='() => ToggleSort("date")'>
                                Aufnahme Datum @SortIndicator("date")
                            </th>
                            <th class="col-size sortable" @onclick='() => ToggleSort("size")'>
                                Dateigröße @SortIndicator("size")
                            </th>
                            <th class="col-type sortable" @onclick='() => ToggleSort("type")'>
                                Datei Typ @SortIndicator("type")
                            </th>
                            <th class="col-gps sortable" @onclick='() => ToggleSort("gps")'>
                                GPS Standort @SortIndicator("gps")
                            </th>
                            <th class="col-tags sortable" @onclick='() => ToggleSort("tags")'>
                                Tags @SortIndicator("tags")
                            </th>
                            <th class="col-status">
                                Pipeline-Status
                            </th>
                        </tr>
                        <tr class="filter-row">
                            <th></th>
                            <th>
                                <select class="filter-select" @bind="_filterDate">
                                    <option value="">Alle</option>
                                    @foreach (var v in DistinctDates)
                                    {
                                        <option value="@v">@v</option>
                                    }
                                </select>
                            </th>
                            <th></th>
                            <th>
                                <select class="filter-select" @bind="_filterType">
                                    <option value="">Alle</option>
                                    @foreach (var v in DistinctTypes)
                                    {
                                        <option value="@v">@v</option>
                                    }
                                </select>
                            </th>
                            <th>
                                <select class="filter-select" @bind="_filterGps">
                                    <option value="">Alle</option>
                                    @foreach (var v in DistinctLocations)
                                    {
                                        <option value="@v">@v</option>
                                    }
                                </select>
                            </th>
                            <th>
                                <select class="filter-select" @bind="_filterTag">
                                    <option value="">Alle</option>
                                    @foreach (var v in DistinctTags)
                                    {
                                        <option value="@v">@v</option>
                                    }
                                </select>
                            </th>
                            <th>
                                <select class="filter-select" @bind="_filterStatus">
                                    <option value="">Alle</option>
                                    <option value="complete">Vollständig</option>
                                    <option value="pending">Ausstehend</option>
                                    <option value="error">Fehler</option>
                                </select>
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in FilteredAndSortedItems)
                        {
                            <tr class="@(item.Id == _selectedId ? "selected" : "")" @onclick="() => SelectItemAsync(item)" @oncontextmenu="(e) => ShowContextMenu(e, item)" @oncontextmenu:preventDefault="true">
                                <td class="col-thumb">
                                    @if (_thumbnails.TryGetValue(item.Id, out var url) && url is not null)
                                    {
                                        <img src="@url" alt="@item.FileName" class="thumb-img" loading="lazy" />
                                    }
                                    else if (item.ContentType.StartsWith("video/", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <span class="thumb-placeholder">🎬</span>
                                    }
                                    else
                                    {
                                        <span class="thumb-placeholder">📷</span>
                                    }
                                </td>
                                <td class="col-date">@item.CreatedAt.LocalDateTime.ToString("dd.MM.yyyy HH:mm")</td>
                                <td class="col-size">@FormatFileSize(item.FileSizeBytes)</td>
                                <td class="col-type">@item.ContentType</td>
                                <td class="col-gps">@FormatGpsLocation(item)</td>
                                <td class="col-tags">
                                    <span class="tag-cell" title="@string.Join(", ", item.Tags)">@(item.Tags.Length > 0 ? item.Tags[0] : "–")</span>
                                </td>
                                <td class="col-status">
                                    @RenderPipelineStatus(item.Id)
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <MediaPreviewPanel
                MediaId="@_selectedId"
                MediaUrl="@_previewUrl"
                AnnotatedUrl="@_annotatedPreviewUrl"
                ContentType="@_selectedItem?.ContentType"
                FileName="@_selectedItem?.FileName"
                FileSizeBytes="@(_selectedItem?.FileSizeBytes ?? 0)"
                IsLoading="@_isLoadingPreview" />
        </div>
    }

    @if (_contextMenuVisible)
    {
        <div class="context-menu" style="left:@(_contextMenuX)px; top:@(_contextMenuY)px;" @onmouseleave="HideContextMenu">
            <div class="context-menu-item" @onclick="FindSimilarPersons">🔍 Ähnliche Person suchen</div>
            <div class="context-menu-item" @onclick="ShowFaces">👤 Gesichter anzeigen</div>
            <div class="context-menu-item context-menu-item-submenu">
                <span>🗂️ Zur Sammlung zuordnen ▶</span>
                <div class="context-submenu">
                    @if (_collections.Count == 0)
                    {
                        <div class="context-menu-item context-menu-item-disabled">Keine Sammlungen vorhanden</div>
                    }
                    else
                    {
                        @foreach (var collection in CollectionsForSubmenu)
                        {
                            var col = collection;
                            <div class="context-menu-item" @onclick="() => AssignToCollectionAsync(col)">🗂️ @col.Name</div>
                        }
                    }
                </div>
            </div>
        </div>
    }

    @if (_similarPersonsVisible && _similarPersons.Count > 0)
    {
        <div class="similar-persons-panel">
            <div class="similar-persons-header">
                <h3>Ähnliche Personen gefunden</h3>
                <button @onclick="CloseSimilarPersons">✕</button>
            </div>
            <div class="similar-persons-list">
                @foreach (var item in _similarPersons)
                {
                    <div class="similar-person-item">
                        @if (_thumbnails.TryGetValue(item.Id, out var thumbUrl) && thumbUrl is not null)
                        {
                            <img src="@thumbUrl" alt="@item.Title" class="similar-person-thumb" loading="lazy" />
                        }
                        else
                        {
                            <span class="similar-person-thumb-placeholder">📷</span>
                        }
                        <strong>@item.Title</strong>
                        <span class="person-badge">👤 @item.PersonCount</span>
                        <span class="tags">@string.Join(", ", item.Tags)</span>
                        <small>@item.CreatedAt.ToString("dd.MM.yyyy HH:mm")</small>
                    </div>
                }
            </div>
        </div>
    }

    @if (_similarPersonsVisible && _similarPersons.Count == 0 && !_isSearching)
    {
        <div class="similar-persons-panel">
            <div class="similar-persons-header">
                <h3>Ähnliche Personen</h3>
                <button @onclick="CloseSimilarPersons">✕</button>
            </div>
            <p>Keine weiteren Medien mit erkannten Personen gefunden.</p>
        </div>
    }

    @if (_facesVisible && _faces.Count > 0)
    {
        <datalist id="face-names-list">
            @foreach (var n in _allFaceNames)
            {
                <option value="@n" />
            }
        </datalist>
        <div class="similar-persons-panel">
            <div class="similar-persons-header">
                <h3>Erkannte Gesichter in "@_contextMenuItem?.FileName"</h3>
                <button @onclick="CloseFaces">✕</button>
            </div>
            <div class="faces-list">
                @for (var i = 0; i < _faces.Count; i++)
                {
                    var face = _faces[i];
                    var faceNumber = i + 1;
                    <div class="face-item">
                        <div class="face-frame">
                            <span class="face-frame-label">@(string.IsNullOrWhiteSpace(face.Name) ? $"Gesicht {faceNumber}" : face.Name)</span>
                        </div>
                        <div class="face-edit">
                            <input list="face-names-list" @bind="_faceNameInputs[face.Id]" placeholder="Name vergeben..." />
                            <button @onclick="() => SaveFaceNameAsync(face.Id)">Speichern</button>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    @if (_facesVisible && _faces.Count == 0 && !_isSearching)
    {
        <div class="similar-persons-panel">
            <div class="similar-persons-header">
                <h3>Gesichter</h3>
                <button @onclick="CloseFaces">✕</button>
            </div>
            <p>Keine Gesichter für dieses Medium gefunden.</p>
        </div>
    }
</div>

<style>
    .context-menu {
        position: fixed;
        background: #1a1a2e;
        border: 1px solid #4a90d9;
        border-radius: 4px;
        box-shadow: 2px 4px 12px rgba(0,0,0,0.4);
        z-index: 1000;
        min-width: 220px;
    }
    .context-menu-item {
        padding: 0.6rem 1rem;
        cursor: pointer;
        color: #f0f0f0;
        font-weight: 500;
        position: relative;
    }
    .context-menu-item:hover { background: #4a90d9; color: #fff; }
    .context-menu-item-disabled { opacity: 0.5; cursor: default; }
    .context-menu-item-disabled:hover { background: transparent; }
    .context-menu-item-submenu { position: relative; }
    .context-submenu {
        display: none;
        position: absolute;
        left: 100%;
        top: 0;
        background: #1a1a2e;
        border: 1px solid #4a90d9;
        border-radius: 4px;
        box-shadow: 2px 4px 12px rgba(0,0,0,0.4);
        min-width: 200px;
        z-index: 1001;
    }
    .context-menu-item-submenu:hover .context-submenu { display: block; }
    .similar-persons-panel {
        margin-top: 1rem;
        border: 1px solid #4a90d9;
        border-radius: 4px;
        padding: 1rem;
        background: #f8fbff;
    }
    .similar-persons-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 0.5rem;
    }
    .similar-persons-header h3 { margin: 0; }
    .similar-person-item {
        border-bottom: 1px solid #ddd;
        padding: 0.5rem 0;
        display: flex;
        gap: 0.5rem;
        align-items: center;
        flex-wrap: wrap;
    }
    .similar-person-thumb {
        width: 48px;
        height: 48px;
        object-fit: cover;
        border-radius: 4px;
        flex-shrink: 0;
    }
    .similar-person-thumb-placeholder {
        width: 48px;
        height: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #e8e8e8;
        border-radius: 4px;
        font-size: 1.4em;
        flex-shrink: 0;
    }
    .person-badge {
        display: inline-block;
        background: #4a90d9;
        color: white;
        border-radius: 12px;
        padding: 2px 8px;
        font-size: 0.8em;
    }
    .tags { color: #666; font-size: 0.85em; }
    .faces-list { display: flex; flex-direction: column; gap: 1rem; }
    .face-item {
        border: 2px solid #4a90d9;
        border-radius: 6px;
        padding: 0.75rem;
        background: white;
        position: relative;
    }
    .face-frame {
        display: flex;
        align-items: center;
        justify-content: center;
        border: 2px dashed #4a90d9;
        border-radius: 4px;
        padding: 1rem;
        margin-bottom: 0.5rem;
        background: #eef4fc;
    }
    .face-frame-label {
        font-weight: 700;
        font-size: 1em;
        color: #2c5f9e;
    }
    .face-edit { display: flex; gap: 0.5rem; }
    .face-edit input { flex: 1; padding: 0.25rem 0.5rem; }
    .filter-select {
        width: 100%;
        padding: 0.2rem 0.3rem;
        border-radius: 4px;
        border: 1px solid #ccc;
        background: #fff;
        font-size: 0.85em;
    }
    .col-tags { min-width: 100px; }
    .tag-cell {
        cursor: default;
        position: relative;
    }
    tr.selected .tag-cell[title]:hover::after {
        content: attr(title);
        position: absolute;
        left: 0;
        top: 100%;
        z-index: 100;
        background: #1a1a2e;
        color: #f0f0f0;
        padding: 0.4rem 0.6rem;
        border-radius: 4px;
        white-space: pre-wrap;
        max-width: 300px;
        font-size: 0.85em;
        box-shadow: 2px 4px 12px rgba(0,0,0,0.4);
    }
    .col-status { min-width: 110px; white-space: nowrap; }
    .pipeline-status-cell { display: flex; gap: 2px; flex-wrap: nowrap; }
    .pipeline-step {
        font-size: 1em;
        cursor: default;
        user-select: none;
    }
</style>

@code {
    private List<MediaItem> _mediaItems = [];
    private readonly Dictionary<Guid, string?> _thumbnails = [];
    private bool _isLoading = true;
    private string? _errorMessage;

    private Guid? _selectedId;
    private MediaItem? _selectedItem;
    private string? _previewUrl;
    private bool _isLoadingPreview;

    // Sort state
    private string? _sortColumn;
    private bool _sortAscending = true;

    // Filter state
    private string _filterDate = string.Empty;
    private string _filterType = string.Empty;
    private string _filterGps = string.Empty;
    private string _filterTag = string.Empty;
    private string _filterStatus = string.Empty;

    // Pipeline status: keyed by MediaId, value is dict of step name -> status
    private Dictionary<Guid, Dictionary<string, ServiceStatus>> _pipelineStatuses = [];

    private IEnumerable<MediaItem> FilteredAndSortedItems
    {
        get
        {
            IEnumerable<MediaItem> items = _mediaItems;

            if (!string.IsNullOrWhiteSpace(_filterDate))
                items = items.Where(i => i.CreatedAt.LocalDateTime.ToString("dd.MM.yyyy") == _filterDate);

            if (!string.IsNullOrWhiteSpace(_filterType))
                items = items.Where(i => i.ContentType == _filterType);

            if (!string.IsNullOrWhiteSpace(_filterGps))
                items = items.Where(i => FormatGpsLocation(i) == _filterGps);

            if (!string.IsNullOrWhiteSpace(_filterTag))
                items = items.Where(i => i.Tags.Contains(_filterTag, StringComparer.OrdinalIgnoreCase));

            if (!string.IsNullOrWhiteSpace(_filterStatus))
            {
                items = _filterStatus switch
                {
                    "complete" => items.Where(i => IsStatusComplete(i.Id)),
                    "pending"  => items.Where(i => HasStatusPending(i.Id)),
                    "error"    => items.Where(i => HasStatusError(i.Id)),
                    _ => items
                };
            }

            if (_sortColumn is not null)
            {
                items = (_sortColumn, _sortAscending) switch
                {
                    ("date", true)  => items.OrderBy(i => i.CreatedAt),
                    ("date", false) => items.OrderByDescending(i => i.CreatedAt),
                    ("size", true)  => items.OrderBy(i => i.FileSizeBytes),
                    ("size", false) => items.OrderByDescending(i => i.FileSizeBytes),
                    ("type", true)  => items.OrderBy(i => i.ContentType, StringComparer.OrdinalIgnoreCase),
                    ("type", false) => items.OrderByDescending(i => i.ContentType, StringComparer.OrdinalIgnoreCase),
                    ("gps", true)   => items.OrderBy(i => FormatGpsLocation(i), StringComparer.OrdinalIgnoreCase),
                    ("gps", false)  => items.OrderByDescending(i => FormatGpsLocation(i), StringComparer.OrdinalIgnoreCase),
                    ("tags", true)  => items.OrderBy(i => i.Tags.FirstOrDefault() ?? string.Empty, StringComparer.OrdinalIgnoreCase),
                    ("tags", false) => items.OrderByDescending(i => i.Tags.FirstOrDefault() ?? string.Empty, StringComparer.OrdinalIgnoreCase),
                    _ => items
                };
            }

            return items;
        }
    }

    private IReadOnlyList<string> DistinctDates =>
        _mediaItems.Select(i => i.CreatedAt.LocalDateTime.ToString("dd.MM.yyyy"))
            .Distinct().OrderDescending().ToList();

    private IReadOnlyList<string> DistinctTypes =>
        _mediaItems.Select(i => i.ContentType)
            .Distinct().Order().ToList();

    private IReadOnlyList<string> DistinctLocations =>
        _mediaItems.Select(i => FormatGpsLocation(i))
            .Where(l => l != "–")
            .Distinct().Order().ToList();

    private IReadOnlyList<string> DistinctTags =>
        _mediaItems.SelectMany(i => i.Tags)
            .Distinct(StringComparer.OrdinalIgnoreCase).Order().ToList();

    private void ToggleSort(string column)
    {
        if (_sortColumn == column)
        {
            if (!_sortAscending)
            {
                // Third click: remove sort
                _sortColumn = null;
                _sortAscending = true;
            }
            else
            {
                _sortAscending = false;
            }
        }
        else
        {
            _sortColumn = column;
            _sortAscending = true;
        }
    }

    private MarkupString SortIndicator(string column)
    {
        if (_sortColumn != column)
            return new MarkupString("<span class=\"sort-indicator\">⇅</span>");
        return _sortAscending
            ? new MarkupString("<span class=\"sort-indicator active\">▲</span>")
            : new MarkupString("<span class=\"sort-indicator active\">▼</span>");
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _mediaItems = await MediaApi.GetMediaAsync();

            foreach (var item in _mediaItems)
            {
                _thumbnails[item.Id] = $"/proxy/thumbnail/{item.Id}";
            }

            _collections = await MediaApi.GetCollectionsAsync();

            var allStatuses = await MediaApi.GetAllPipelineStatusesAsync();
            _pipelineStatuses = allStatuses
                .GroupBy(s => s.MediaId)
                .ToDictionary(
                    g => g.Key,
                    g => g.ToDictionary(s => s.StepName, s => s.Status));
        }
        catch (Exception ex)
        {
            _errorMessage = $"Fehler beim Laden der Medien: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task SelectItemAsync(MediaItem item)
    {
        if (_selectedId == item.Id)
            return;

        _selectedId = item.Id;
        _selectedItem = item;
        _previewUrl = $"/proxy/media/{item.Id}";
        _isLoadingPreview = false;

        // Close the faces panel and clear cached data for the previous item
        _facesVisible = false;
        _faces = [];
        _faceNameInputs = [];
        _cachedImageBytes = null;
        _annotatedPreviewUrl = null;

        // When "Immer erkannte Gesichter mit Rahmen versehen" is enabled, auto-render bboxes
        if (GallerySettings.AlwaysShowFaceBboxes)
        {
            try
            {
                var facesForItem = await MediaApi.GetFacesAsync(item.Id);
                if (facesForItem.Count > 0)
                {
                    _cachedImageBytes = await MediaApi.DownloadImageBytesAsync(item.Id);
                    _annotatedPreviewUrl = FaceImageRenderer.Render(_cachedImageBytes, facesForItem);
                }
            }
            catch (Exception ex)
            {
                // Log the error but keep the plain preview as fallback
                _errorMessage = ex.Message;
            }
        }
    }

    private bool _contextMenuVisible;
    private double _contextMenuX;
    private double _contextMenuY;
    private MediaItem? _contextMenuItem;

    private bool _isSearching;
    private bool _similarPersonsVisible;
    private List<MediaItem> _similarPersons = [];

    private bool _facesVisible;
    private List<Face> _faces = [];
    private Dictionary<Guid, string?> _faceNameInputs = [];
    private string? _annotatedPreviewUrl;
    private byte[]? _cachedImageBytes;
    private List<string> _allFaceNames = [];

    // Collections
    private List<CollectionDto> _collections = [];
    private Guid? _lastUsedCollectionId;

    private IEnumerable<CollectionDto> CollectionsForSubmenu
    {
        get
        {
            if (_lastUsedCollectionId.HasValue)
            {
                var last = _collections.FirstOrDefault(c => c.Id == _lastUsedCollectionId.Value);
                if (last is not null)
                    return [last, .. _collections.Where(c => c.Id != _lastUsedCollectionId.Value).OrderBy(c => c.Name, StringComparer.OrdinalIgnoreCase)];
            }
            return _collections.OrderBy(c => c.Name, StringComparer.OrdinalIgnoreCase);
        }
    }

    private async Task AssignToCollectionAsync(CollectionDto collection)
    {
        _contextMenuVisible = false;
        if (_contextMenuItem is null) return;
        try
        {
            await MediaApi.AddMediaToCollectionAsync(collection.Id, _contextMenuItem.Id);
            _lastUsedCollectionId = collection.Id;
            _errorMessage = null;
        }
        catch (Exception ex)
        {
            _errorMessage = $"Fehler beim Zuordnen zur Sammlung: {ex.Message}";
        }
    }

    private void ShowContextMenu(Microsoft.AspNetCore.Components.Web.MouseEventArgs e, MediaItem item)
    {
        _contextMenuX = e.ClientX;
        _contextMenuY = e.ClientY;
        _contextMenuItem = item;
        _contextMenuVisible = true;
        _similarPersonsVisible = false;
        _facesVisible = false;
    }

    private void HideContextMenu() => _contextMenuVisible = false;

    private async Task FindSimilarPersons()
    {
        _contextMenuVisible = false;
        if (_contextMenuItem is null) return;
        _isSearching = true;
        _similarPersonsVisible = true;
        _facesVisible = false;
        try
        {
            _similarPersons = await MediaApi.FindSimilarPersonsAsync(_contextMenuItem.Id);
            foreach (var p in _similarPersons.Where(p => !_thumbnails.ContainsKey(p.Id)))
            {
                _thumbnails[p.Id] = $"/proxy/thumbnail/{p.Id}";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
            _similarPersons = [];
        }
        finally { _isSearching = false; }
    }

    private async Task ShowFaces()
    {
        _contextMenuVisible = false;
        if (_contextMenuItem is null) return;

        if (_selectedId != _contextMenuItem.Id)
            await SelectItemAsync(_contextMenuItem);

        _isSearching = true;
        _facesVisible = true;
        _similarPersonsVisible = false;
        _annotatedPreviewUrl = null;
        _cachedImageBytes = null;
        try
        {
            _faces = await MediaApi.GetFacesAsync(_contextMenuItem.Id);
            _faceNameInputs = _faces.ToDictionary(f => f.Id, f => f.Name);
            _allFaceNames = await MediaApi.GetFaceNamesAsync();

            if (_faces.Count > 0 && _contextMenuItem is not null)
            {
                _cachedImageBytes = await MediaApi.DownloadImageBytesAsync(_contextMenuItem.Id);
                _annotatedPreviewUrl = FaceImageRenderer.Render(_cachedImageBytes, _faces);
            }
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
            _faces = [];
        }
        finally { _isSearching = false; }
    }

    private async Task SaveFaceNameAsync(Guid faceId)
    {
        if (!_faceNameInputs.TryGetValue(faceId, out var name)) return;
        try
        {
            await MediaApi.UpdateFaceNameAsync(faceId, name);
            var face = _faces.FirstOrDefault(f => f.Id == faceId);
            if (face is not null)
            {
                var idx = _faces.IndexOf(face);
                _faces[idx] = face with { Name = name };
            }

            // Refresh the autocomplete list if a new name was entered
            if (!string.IsNullOrWhiteSpace(name) && !_allFaceNames.Contains(name, StringComparer.OrdinalIgnoreCase))
                _allFaceNames.Add(name);

            // Regenerate the annotated preview to reflect the updated label
            if (_cachedImageBytes is not null && _faces.Count > 0)
                _annotatedPreviewUrl = FaceImageRenderer.Render(_cachedImageBytes, _faces);
        }
        catch (Exception ex) { _errorMessage = ex.Message; }
    }

    private void CloseSimilarPersons()
    {
        _similarPersonsVisible = false;
        _similarPersons = [];
    }

    private void CloseFaces()
    {
        _facesVisible = false;
        _faces = [];
        _faceNameInputs = [];
        _annotatedPreviewUrl = null;
        _cachedImageBytes = null;
    }

    private static readonly string[] PipelineStepNames =
    [
        "ThumbnailGeneration",
        "ObjectRecognition",
        "FaceRecognition",
        "Geocoding"
    ];

    private static readonly Dictionary<string, string> StepLabels = new()
    {
        ["ThumbnailGeneration"] = "Thumbnail",
        ["ObjectRecognition"]   = "Objekte",
        ["FaceRecognition"]     = "Gesichter",
        ["Geocoding"]           = "Geocoding"
    };

    private bool IsStatusComplete(Guid mediaId) =>
        _pipelineStatuses.TryGetValue(mediaId, out var steps) &&
        PipelineStepNames.All(s => steps.TryGetValue(s, out var v) && v == ServiceStatus.Success);

    private bool HasStatusPending(Guid mediaId) =>
        !_pipelineStatuses.TryGetValue(mediaId, out var steps) ||
        PipelineStepNames.Any(s => !steps.ContainsKey(s));

    private bool HasStatusError(Guid mediaId) =>
        _pipelineStatuses.TryGetValue(mediaId, out var steps) &&
        PipelineStepNames.Any(s => steps.TryGetValue(s, out var v) && v == ServiceStatus.Error);

    private MarkupString RenderPipelineStatus(Guid mediaId)
    {
        _pipelineStatuses.TryGetValue(mediaId, out var steps);
        steps ??= [];

        var sb = new System.Text.StringBuilder();
        sb.Append("<span class=\"pipeline-status-cell\">");
        foreach (var step in PipelineStepNames)
        {
            var label = StepLabels.TryGetValue(step, out var l) ? l : step;
            if (steps.TryGetValue(step, out var status))
            {
                var (icon, cssClass) = status switch
                {
                    ServiceStatus.Success => ("✅", "status-ok"),
                    ServiceStatus.Error   => ("❌", "status-err"),
                    _                     => ("⏳", "status-pending")
                };
                sb.Append($"<span class=\"pipeline-step {cssClass}\" title=\"{label}\">{icon}</span>");
            }
            else
            {
                sb.Append($"<span class=\"pipeline-step status-pending\" title=\"{label}\">⏳</span>");
            }
        }
        sb.Append("</span>");
        return new MarkupString(sb.ToString());
    }

    private static string FormatFileSize(long bytes) => bytes switch
    {
        < 1024 => $"{bytes} B",
        < 1024 * 1024 => $"{bytes / 1024.0:F1} KB",
        < 1024 * 1024 * 1024 => $"{bytes / (1024.0 * 1024):F1} MB",
        _ => $"{bytes / (1024.0 * 1024 * 1024):F1} GB"
    };

    private static string FormatGpsLocation(MediaItem item)
    {
        if (!string.IsNullOrWhiteSpace(item.GpsLocation))
            return item.GpsLocation;

        if (item.GpsLatitude.HasValue && item.GpsLongitude.HasValue)
            return $"{item.GpsLatitude:F4}°, {item.GpsLongitude:F4}°";

        return "–";
    }
}
